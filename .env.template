# CodeSense Environment Variables
# Copy this file to .env and fill in your values.

# Gemini API keys for multi-key rotation (at least one required)
GEMINI_KEY_1=your_gemini_api_key_1_here
GEMINI_KEY_2=your_gemini_api_key_2_here

# GitHub personal access token for issue/PR retrieval
GITHUB_TOKEN=your_github_token_here

# Set to "true" to use mock data sources (no credentials needed)
CODESENSE_MOCK=false

# Minutes before retrying a rate-limited key (default: 1)
BACKOFF_MINUTES=1
